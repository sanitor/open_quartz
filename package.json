{
  "name": "open-quartz",
  "private": true,
  "version": "0.13.0b",
  "type": "module",
  "scripts": {
    "predev": "npm run copy:ort",
    "dev": "vite",
    "prebuild": "npm run copy:ort",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:models": "vitest run --config vitest.functional.config.ts",
    "test:shaders": "vitest run --config vitest.shaders.config.ts",
    "build:wasm": "wasm-pack build rust/crates/yolo-detector --target web --release --out-dir pkg",
    "build:wasm:seg": "wasm-pack build rust/crates/yolo-sem --target web --release --out-dir pkg",
    "copy:ort": "node scripts/copy-ort.mjs",
    "clean": "rm -rf dist node_modules/.vite src-tauri/target"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@xyflow/react": "^12.11.1",
    "codemirror": "^6.0.2",
    "codemirror-lang-glsl": "^0.5.0",
    "immer": "^11.1.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-preview": "^4.1.10",
    "@vitest/coverage-istanbul": "^4.1.10",
    "jsdom": "^29.1.1",
    "onnxruntime-node": "^1.21.1",
    "onnxruntime-web": "^1.27.0",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
